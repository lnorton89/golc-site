    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.11",
    "linkinator": "^8.0.1",
    "serve": "^14.2.6",
    "start-server-and-test": "^3.0.11",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
